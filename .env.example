# =============================================================================
# Code Review Agent Configuration
# =============================================================================

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-string

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./github-app-key.pem
GITHUB_WEBHOOK_SECRET=
GITHUB_API_URL=https://api.github.com

# --- LLM Provider ---
LLM_PROVIDER=openai  # openai, anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Embeddings ---
EMBEDDING_PROVIDER=openai  # openai, sentence_transformers
EMBEDDING_MODEL=text-embedding-3-small

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/code_review_agent
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Vector Store ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_PERSIST_DIR=./data/chromadb

# --- Docker Sandbox ---
DOCKER_SOCKET=unix:///var/run/docker.sock
SANDBOX_TIMEOUT=300
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0

# --- Security Scanner ---
ENABLE_SECURITY_SCAN=true
SECURITY_SCAN_TOOLS=bandit,semgrep

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
